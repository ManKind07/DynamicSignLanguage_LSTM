   "source": [
    "def extract_keypoints(results):\n",
    "    # --- POSE ---\n",
    "    if results.pose_landmarks:\n",
    "        pose = []\n",
    "        res = results.pose_landmarks.landmark[0]\n",
    "        pose.append(np.array([res.x,res.y,res.z,res.visibility]))\n",
    "        for i in range(11,23):\n",
    "            res = results.pose_landmarks.landmark[i]\n",
    "            pose.append(np.array([res.x,res.y,res.z,res.visibility]))\n",
    "    \n",
    "        pose = np.array(pose).flatten()\n",
    "    else:\n",
    "        pose = np.zeros(52)\n",
    "    \n",
    "    \n",
    "    # --- LEFT HAND ---\n",
    "    if results.left_hand_landmarks:\n",
    "        lh = np.array([[res.x, res.y, res.z] for res in results.left_hand_landmarks.landmark]).flatten()\n",
    "    else:\n",
    "        # 21 landmarks * 3 coordinates = 63 zeros\n",
    "        lh = np.zeros(21 * 3) \n",
    "    \n",
    "    # --- RIGHT HAND ---\n",
    "    if results.right_hand_landmarks:\n",
    "        rh = np.array([[res.x, res.y, res.z] for res in results.right_hand_landmarks.landmark]).flatten()\n",
    "    else:\n",
    "        rh = np.zeros(21 * 3)\n",
    "    \n",
    "    # NOTE: Grab only x y z coordinates and ignore visibility attribute as it can mess with the LSTM model further\n",
    "    \n",
    "    # print(len(pose))\n",
    "    # print(len(rh))\n",
    "    # print(len(lh))\n",
    "    return np.concatenate([pose, rh, lh])"
   ]
  },
