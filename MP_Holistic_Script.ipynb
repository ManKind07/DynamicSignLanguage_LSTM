   "source": [
    "from tensorflow.keras.models import Sequential\n",
    "from tensorflow.keras.layers import LSTM, Dense, Bidirectional, Dropout\n",
    "from tensorflow.keras.optimizers import Adam\n",
    "from tensorflow.keras.callbacks import EarlyStopping, ReduceLROnPlateau\n",
    "\n",
    "model = Sequential()\n",
    "\n",
    "# LAYER 1: Time-series extraction\n",
    "model.add(Bidirectional(LSTM(64, return_sequences=True, activation='relu'), input_shape=(30, 178)))\n",
    "model.add(Dropout(0.2))\n",
    "\n",
    "# LAYER 2: Deep feature extraction\n",
    "model.add(Bidirectional(LSTM(64, return_sequences=False, activation='relu')))\n",
    "model.add(Dropout(0.2))\n",
    "\n",
    "# --- TWEAK 1: WIDENED DENSE FUNNEL ---\n",
    "# Bumped up to give the brain more \"room\" to map 6 distinct classes\n",
    "model.add(Dense(128, activation='relu')) \n",
    "model.add(Dense(64, activation='relu'))  \n",
    "\n",
    "# Final output layer (Automatically adjusts to 6 based on your actions array)\n",
    "model.add(Dense(actions.shape[0], activation='softmax'))\n",
    "\n",
    "# --- OPTIMIZER ---\n",
    "custom_optimizer = Adam(learning_rate=0.0001, clipnorm=1.0)\n",
    "\n",
    "model.compile(optimizer=custom_optimizer, \n",
    "              loss='categorical_crossentropy', \n",
    "              metrics=['categorical_accuracy'])\n",
    "\n",
    "# --- TWEAK 2: TRUE VALIDATION TRACKING ---\n",
    "# Watch 'val_loss' instead of 'loss' to ensure it's actually generalizing\n",
    "early_stopping = EarlyStopping(monitor='val_loss', patience=25, restore_best_weights=True)\n",
    "\n",
    "# --- PRO TIP: LEARNING RATE REDUCTION ---\n",
    "# If the model gets stuck, automatically drop the learning rate to make finer adjustments\n",
    "lr_scheduler = ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=10, min_lr=0.00001)\n",
    "\n",
    "# --- TWEAK 3: THE VALIDATION SPLIT ---\n",
    "# Force the model to test itself on 20% of the data it hasn't seen\n",
    "history = model.fit(X_train, y_train, \n",
    "                    validation_split=0.2, \n",
    "                    epochs=500, \n",
    "                    callbacks=[early_stopping, lr_scheduler])"
   ]
