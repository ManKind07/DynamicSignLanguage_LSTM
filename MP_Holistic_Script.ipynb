    "import time\n",
    "\n",
    "cap = cv2.VideoCapture(0)\n",
    "\n",
    "# 1. Create a kill switch variable\n",
    "kill_switch = False\n",
    "\n",
    "with mp_holistic.Holistic(min_detection_confidence=0.5, min_tracking_confidence=0.5) as holistic:\n",
    "    \n",
    "    for action in actions:\n",
    "        if kill_switch: break # Check kill switch\n",
    "            \n",
    "        for sequence in range(start_folder, start_folder+no_sequences):\n",
    "            if kill_switch: break # Check kill switch\n",
    "                \n",
    "            # --- PHASE 1: THE WAITING ROOM ---\n",
    "            # Pauses here until you hit SPACEBAR. Keeps camera feed live so you can position yourself.\n",
    "            while True:\n",
    "                ret, frame = cap.read()\n",
    "                \n",
    "                # Display instructions\n",
    "                cv2.putText(frame, f'Ready for: {action} | Video: {sequence}', (15, 50), \n",
    "                           cv2.FONT_HERSHEY_SIMPLEX, 1, (255, 0, 0), 2, cv2.LINE_AA)\n",
    "                cv2.putText(frame, 'Press SPACEBAR to Start', (15, 90), \n",
    "                           cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 255, 0), 2, cv2.LINE_AA)\n",
    "                cv2.putText(frame, 'Press \"q\" to Quit', (15, 130), \n",
    "                           cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 0, 255), 2, cv2.LINE_AA)\n",
    "                \n",
    "                cv2.imshow('OpenCV Feed', frame)\n",
    "                \n",
    "                # Wait for key press\n",
    "                key = cv2.waitKey(10) & 0xFF\n",
    "                if key == ord(' '):  # 32 is the ASCII code for SPACEBAR, but ord(' ') is safer\n",
    "                    break\n",
    "                elif key == ord('q'): # Emergency quit\n",
    "                    kill_switch = True\n",
    "                    break\n",
    "                    \n",
    "            if kill_switch: break\n",
    "\n",
    "            # --- PHASE 2: THE LIVE COUNTDOWN ---\n",
    "            # Counts down 3, 2, 1 without freezing the camera feed\n",
    "            for i in range(3, 0, -1):\n",
    "                start_time = time.time()\n",
    "                # Run this sub-loop for exactly 1.0 second per number\n",
    "                while time.time() - start_time < 1.0:\n",
    "                    ret, frame = cap.read()\n",
    "                    \n",
    "                    # Draw a massive countdown number in the middle of the screen\n",
    "                    cv2.putText(frame, str(i), (280, 280), \n",
    "                               cv2.FONT_HERSHEY_SIMPLEX, 6, (0, 255, 0), 10, cv2.LINE_AA)\n",
    "                    \n",
    "                    cv2.imshow('OpenCV Feed', frame)\n",
    "                    cv2.waitKey(10)\n",
    "\n",
    "            # --- PHASE 3: THE ACTUAL RECORDING LOOP ---\n",
    "            for frame_num in range(sequence_length):\n",
    "\n",
    "                ret, frame = cap.read()\n",
    "                image, results = mediapipe_detection(frame, holistic)\n",
    "                draw_styled_landmarks(image, results)\n",
    "                \n",
    "                # Simple red recording indicator\n",
    "                cv2.putText(image, f'RECORDING: {action} Video {sequence}', (15,30), \n",
    "                           cv2.FONT_HERSHEY_SIMPLEX, 1, (0, 0, 255), 2, cv2.LINE_AA)\n",
    "                \n",
    "                cv2.imshow('OpenCV Feed', image)\n",
    "                \n",
    "                # Export keypoints\n",
    "                keypoints = extract_keypoints(results)\n",
    "                sequence_folder = os.path.join(DATA_PATH, action, str(sequence))\n",
    "                os.makedirs(sequence_folder, exist_ok=True)\n",
    "                npy_path = os.path.join(sequence_folder, str(frame_num))\n",
    "                np.save(npy_path, keypoints)\n",
    "\n",
    "                # Keep the panic quit button active during recording\n",
    "                if cv2.waitKey(10) & 0xFF == ord('q'):\n",
    "                    kill_switch = True \n",
    "                    break \n",
    "                    \n",
    "    cap.release()\n",
    "    cv2.destroyAllWindows()"
