    "from tensorflow.keras.models import Sequential\n",
    "from tensorflow.keras.layers import LSTM, Dense, Bidirectional\n",
    "\n",
    "model = Sequential()\n",
    "\n",
    "# LAYER 1: Wrapped in Bidirectional. We pass the input_shape to the Bidirectional wrapper.\n",
    "model.add(Bidirectional(LSTM(64, return_sequences=True, activation='relu'), input_shape=(30, 178)))\n",
    "\n",
    "# LAYER 2: Also wrapped. return_sequences is False because we are about to pass to Dense layers.\n",
    "model.add(Bidirectional(LSTM(64, return_sequences=False, activation='relu')))\n",
    "\n",
    "# Dense Layers: The same optimized funnel\n",
    "model.add(Dense(64, activation='relu'))\n",
    "model.add(Dense(32, activation='relu'))\n",
    "\n",
    "# Final output layer\n",
    "model.add(Dense(actions.shape[0], activation='softmax'))"
   ]
