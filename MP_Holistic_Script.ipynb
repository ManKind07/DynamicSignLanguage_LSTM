    "import cv2
import numpy as np
import mediapipe as mp

def predict_single_video(video_path):
    sequence = []
    cap = cv2.VideoCapture(video_path)

    with mp_holistic.Holistic(min_detection_confidence=0.5, min_tracking_confidence=0.5) as holistic:
        while cap.isOpened():
            ret, frame = cap.read()
            
            # Stop if the video ends, or if we have collected our 30 frames
            if not ret or len(sequence) == 30:
                break

            # Extract features silently (no drawing functions needed!)
            image, results = mediapipe_detection(frame, holistic)
            keypoints = extract_keypoints(results)
            sequence.append(keypoints)
            
    cap.release()

    # Make the prediction if we successfully grabbed 30 frames
    if len(sequence) == 30:
        # Expand dimensions to (1, 30, 178)
        input_data = np.expand_dims(sequence, axis=0)
        
        # Get the prediction array using the fast direct call
        res = model(input_data, training=False).numpy()[0]
        
        # Find the top result
        top_action = actions[np.argmax(res)]
        confidence = res[np.argmax(res)]
        
        print("-" * 30)
        print("VIDEO ANALYSIS COMPLETE")
        print(f"Predicted Action : {top_action.upper()}")
        print(f"Confidence Score : {confidence * 100:.2f}%")
        print("-" * 30)
        
        return top_action, confidence
    else:
        print(f"Error: The video only had {len(sequence)} readable frames. Expected 30.")
        return None, None

# --- How to use it ---
# Just put your video path here:
action, conf = predict_single_video('black.mp4')"
